# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL (required for users and orders)
DB_HOST=your-db-host.example.com
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_PORT=5432
DB_NAME=your_database_name
# Set to true when connecting to a server that requires TLS (common on remote hosts)
DB_SSL=false
# When DB_SSL=true, set to false only if you use a self-signed cert and accept the risk
DB_SSL_REJECT_UNAUTHORIZED=true

# Auth
JWT_SECRET=replace-with-strong-secret

# MailEnable SMTP
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@karateskillzdojo.local
CONTACT_TO=admin@karateskillzdojo.com
ADMIN_ORDER_NOTIFY_TO=admin@karateskillzdojo.com
